{
    "name": "mrkindy/multi-tenant-wordpress",
    "description": "Database-per-tenant bootstrap for WordPress and WooCommerce SaaS platforms.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "wordpress",
        "woocommerce",
        "multi-tenant",
        "saas",
        "database"
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "aws/aws-sdk-php": "^3.300",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "MrKindy\\MultiTenantWordPress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MrKindy\\MultiTenantWordPress\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=1G",
        "cs": "phpcs",
        "check": [
            "@test",
            "@analyse",
            "@cs"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
